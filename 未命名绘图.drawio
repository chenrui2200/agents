        <mxCell id="suS-wiGyDA5d7vcld8C9-9" parent="1" style="whiteSpace=wrap;strokeWidth=2;labelBackgroundColor=none;fillColor=#ffcc99;strokeColor=#36393d;" value="1. 投标业务服务&#xa;• 标书识别（OCR+NER+RAG）&#xa;• 施工组织设计生成（CoT+领域LLM）&#xa;• 人员证件匹配（外部接口查询）&#xa;• 报价风险预测（时间序列）" vertex="1">
          <mxGeometry height="181" width="260" x="1060" y="650" as="geometry" />
        </mxCell>
        <mxCell id="suS-wiGyDA5d7vcld8C9-10" parent="1" style="whiteSpace=wrap;strokeWidth=2;labelBackgroundColor=none;fillColor=#ffcc99;strokeColor=#36393d;" value="2. 招投标管理服务&#xa;• 招标文件规范审查（Sentence-BERT）&#xa;• 供应商画像+围标检测（Neo4j+Louvain+Isolation Forest）" vertex="1">
          <mxGeometry height="174" width="260" x="411" y="993" as="geometry" />
        </mxCell>
        <mxCell id="suS-wiGyDA5d7vcld8C9-11" parent="1" style="whiteSpace=wrap;strokeWidth=2;labelBackgroundColor=none;fillColor=#ffcc99;strokeColor=#36393d;" value="3. 合同管理服务&#xa;• 合同比对（Diff-Match-Patch）&#xa;• 风险条款提取（BiLSTM-CRF）&#xa;• 动态台账（ETL联邦查询）" vertex="1">
          <mxGeometry height="174" width="260" x="1378" y="673" as="geometry" />
        </mxCell>
        <mxCell id="suS-wiGyDA5d7vcld8C9-12" parent="1" style="whiteSpace=wrap;strokeWidth=2;labelBackgroundColor=none;fillColor=#ffcc99;strokeColor=#36393d;" value="4. 生产管理服务&#xa;• 规范问答（Milvus RAG）&#xa;• 图纸审计（CV）&#xa;• 机械调度（遗传算法+离散事件模拟）" vertex="1">
          <mxGeometry height="222" width="260" x="830" y="969" as="geometry" />
        </mxCell>
        <mxCell id="suS-wiGyDA5d7vcld8C9-13" parent="1" style="whiteSpace=wrap;strokeWidth=2;labelBackgroundColor=none;fillColor=#ffcc99;strokeColor=#36393d;" value="5. 分包与结算服务&#xa;• 发票去重（哈希+近似搜索）&#xa;• 定额对标（LLM语义映射）&#xa;• 产值自动核算（数据驱动计价）" vertex="1">
